/* USER CODE BEGIN Header_StartDefaultTask */
/**
  * @brief  Function implementing the defaultTask thread.
  * @param  argument: Not used
  * @retval None
  */
/* USER CODE END Header_StartDefaultTask */
void StartDefaultTask(void *argument)
{
  /* USER CODE BEGIN StartDefaultTask */
  (void) argument;
  extern UART_HandleTypeDef huart3;
  extern robot_status_t robot_state;
  const uint32_t publish_period_ms = 25U;

#if UART3_SMOKE_TEST
  static const uint8_t banner[] = "UART3 alive\r\n";

  for (;;) {
      HAL_UART_Transmit(&huart3, (uint8_t *) banner, sizeof(banner) - 1U, HAL_MAX_DELAY);
      osDelay(1000);
  }
#else
  rmw_uros_set_custom_transport(
    true,
    (void *) &huart3,
    cubemx_transport_open,
    cubemx_transport_close,
    cubemx_transport_write,
    cubemx_transport_read
  );

  rcl_allocator_t freeRTOS_allocator = rcutils_get_zero_initialized_allocator();
  freeRTOS_allocator.allocate = microros_allocate;
  freeRTOS_allocator.deallocate = microros_deallocate;
  freeRTOS_allocator.reallocate = microros_reallocate;
  freeRTOS_allocator.zero_allocate =  microros_zero_allocate;

  if (!rcutils_set_default_allocator(&freeRTOS_allocator)) {
      Error_Handler();
  }

  rcl_allocator_t allocator = rcl_get_default_allocator();
  rclc_support_t support = {0};
  rcl_node_t node = rcl_get_zero_initialized_node();
  rcl_publisher_t publisher = rcl_get_zero_initialized_publisher();
  geometry_msgs__msg__Twist msg = {0};
  rcl_ret_t rc = RCL_RET_OK;

  do {
      rc = rclc_support_init(&support, 0, NULL, &allocator);
      if (rc != RCL_RET_OK) {
          osDelay(100);
      }
  } while(rc != RCL_RET_OK);

  rc = rclc_node_init_default(&node, "cubemx_node", "", &support);
  if (rc != RCL_RET_OK) {
      Error_Handler();
  }

  rc = rclc_publisher_init_default(
    &publisher,
    &node,
    ROSIDL_GET_MSG_TYPE_SUPPORT(geometry_msgs, msg, Twist),
    "odom_vel"
  );
  if (rc != RCL_RET_OK) {
      Error_Handler();
  }

  for (uint32_t i = 0; i < WHEEL_COUNT; ++i) {
      robot_state.wheels[i].total_tick = get_total_encoder_tick(&robot_state.wheels[i]);
      robot_state.wheels[i].prev_tick = robot_state.wheels[i].total_tick;
  }

  msg.linear.x = 0.0;
  msg.linear.y = 0.0;
  msg.linear.z = 0.0;
  msg.angular.x = 0.0;
  msg.angular.y = 0.0;
  msg.angular.z = 0.0;

  uint32_t last_sample_ms = osKernelGetTickCount();

  for(;;)
  {
      osDelay(publish_period_ms);

      uint32_t now_ms = osKernelGetTickCount();
      float dt = (float)(now_ms - last_sample_ms) / 1000.0f;
      if (dt <= 0.0f) {
          dt = (float) publish_period_ms / 1000.0f;
      }
      last_sample_ms = now_ms;

      for (uint32_t i = 0; i < WHEEL_COUNT; ++i) {
          wheel_update_velocity(&robot_state.wheels[i], dt);
      }

      calculate_robot_kinematics(&robot_state);

      msg.linear.x = robot_state.robot_linear_v;
      msg.angular.z = robot_state.robot_angular_w;

      rc = rcl_publish(&publisher, &msg, NULL);
      if (rc != RCL_RET_OK) {
          Error_Handler();
      }
  }
#endif
  /* USER CODE END StartDefaultTask */
}

